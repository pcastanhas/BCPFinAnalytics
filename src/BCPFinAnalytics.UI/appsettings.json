{
  "ConnectionStrings": {
    "PROD": "Server=;Database=;User Id=;Password=;TrustServerCertificate=True;",
    "TEST": "Server=;Database=;User Id=;Password=;TrustServerCertificate=True;",
    "DEV": "Server=;Database=;User Id=;Password=;TrustServerCertificate=True;"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Verbose",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/BCPFinAnalytics-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AppSettings": {
    "AppName": "BCPFinAnalytics",
    "AppVersion": "1.0",
    "CrosstabMaxEntitiesForPdf": 10
  }
}
