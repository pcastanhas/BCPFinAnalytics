@inherits LayoutComponentBase
@inject IOptions<AppSettings> AppSettingsOptions
@using BCPFinAnalytics.Services
@using Microsoft.Extensions.Options
@using MudBlazor

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<AlertDisplay />

<MudLayout>

    <!-- ═══════════════════════════════════════════════════
         APP BANNER — always visible, shows name + version
         ═══════════════════════════════════════════════════ -->
    <MudAppBar Elevation="2" Color="Color.Primary" Fixed="true">
        <MudIcon Icon="@Icons.Material.Filled.Analytics" Class="mr-2" />
        <MudText Typo="Typo.h6" Style="font-weight:600; letter-spacing:0.05em;">
            @AppSettingsOptions.Value.AppName
        </MudText>
        <MudText Typo="Typo.caption" Class="ml-2 mt-1" Style="opacity:0.75;">
            @("v" + AppSettingsOptions.Value.AppVersion)
        </MudText>
        <MudSpacer />
        <SessionBadge />
    </MudAppBar>

    <!-- ═══════════════════════════════════════════════════
         MAIN CONTENT AREA
         ═══════════════════════════════════════════════════ -->
    <MudMainContent Class="mt-16 px-3 pt-2" Style="height:calc(100vh - 68px); overflow:hidden; display:flex; flex-direction:column;">
        <ErrorBoundary>
            <ChildContent>
                @Body
            </ChildContent>
            <ErrorContent Context="ex">
                <MudAlert Severity="Severity.Error" Class="ma-4">
                    <MudText Typo="Typo.subtitle1">An unexpected error occurred.</MudText>
                    <MudText Typo="Typo.body2">@ex.Message</MudText>
                </MudAlert>
            </ErrorContent>
        </ErrorBoundary>
    </MudMainContent>

</MudLayout>
