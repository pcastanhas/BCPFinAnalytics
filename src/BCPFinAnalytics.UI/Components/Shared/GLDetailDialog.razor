@using BCPFinAnalytics.Common.DTOs
@using BCPFinAnalytics.Common.Models
@using BCPFinAnalytics.Services.GlDetail
@using BCPFinAnalytics.Services.Session
@inject IGlDetailService GlDetailService
@inject UserSessionService UserSession
@inject ISnackbar Snackbar
@inject BCPFinAnalytics.UI.Services.AlertService AlertSvc
@inject ILogger<GLDetailDialog> Logger
@inject IJSRuntime JS

@*
    GLDetailDialog — GL transaction drill-down modal.
    Opens when a drillable cell is clicked in ReportDisplay.
    Shows JOURNAL (open) + GHIS (closed) rows for the clicked cell context.

    Supports:
      - Single or multiple entities (consolidated reports)
      - Single or multiple accounts (subtotal-level detail)
      - Basis expansion (A/C automatically includes B rows)
*@

<MudDialog Style="min-width:900px; max-width:98vw;">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Receipt" Color="Color.Primary" />
            <div>
                <MudText Typo="Typo.h6">GL Detail</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @DrillDown.DisplayLabel
                </MudText>
            </div>
        </MudStack>
    </TitleContent>

    <DialogContent>
        @if (_loading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-4 text-center">
                Loading transactions...
            </MudText>
        }
        else if (_rows.Count == 0)
        {
            <MudAlert Severity="Severity.Info">
                No transactions found for the selected criteria.
                @if (DrillDown.StartingBalance.HasValue || DrillDown.EndingBalance.HasValue)
                {
                    <span> Balance: @FormatAmount(DrillDown.EndingBalance ?? DrillDown.StartingBalance ?? 0m)</span>
                }
            </MudAlert>
        }
        else
        {
            <!-- Summary line -->
            <MudStack Row="true" Spacing="3" Class="mb-3" AlignItems="AlignItems.Center">
                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Icon="@Icons.Material.Filled.Receipt">
                    @_rows.Count transaction@(_rows.Count == 1 ? "" : "s")
                </MudChip>
                <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.AttachMoney">
                    Total: @FormatAmount(_rows.Sum(r => r.Amt))
                </MudChip>
                <MudSpacer />
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @DrillDown.PeriodFrom – @DrillDown.PeriodTo
                </MudText>
            </MudStack>

            <!-- Transaction table -->
            <div class="gl-detail-container">
                <table class="gl-detail-table">
                    <thead>
                        <tr>
                            <th>Period</th>
                            <th>Ref</th>
                            <th>Source</th>
                            <th>Basis</th>
                            @if (DrillDown.EntityIds.Count > 1)
                            {
                                <th>Entity</th>
                            }
                            @if (DrillDown.AcctNums.Count > 1)
                            {
                                <th>Account</th>
                            }
                            <th>Dept</th>
                            <th>Item</th>
                            <th>Job</th>
                            <th>Date</th>
                            <th style="min-width:200px;">Description</th>
                            <th>Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (DrillDown.StartingBalance.HasValue)
                        {
                            <tr class="gl-detail-balance-row">
                                <td colspan="@(TotalColspan - 1)"><strong>Starting Balance</strong></td>
                                <td class="amount @(DrillDown.StartingBalance.Value < 0 ? "negative" : "")">
                                    <strong>@FormatAmount(DrillDown.StartingBalance.Value)</strong>
                                </td>
                            </tr>
                        }
                        @foreach (var row in _rows)
                        {
                            <tr class="gl-detail-row">
                                <td>@FormatPeriod(row.Period)</td>
                                <td class="mono">@row.Ref</td>
                                <td>@row.Source</td>
                                <td>@row.Basis</td>
                                @if (DrillDown.EntityIds.Count > 1)
                                {
                                    <td class="mono">@row.EntityId</td>
                                }
                                @if (DrillDown.AcctNums.Count > 1)
                                {
                                    <td class="mono">@row.AcctNum.Trim()</td>
                                }
                                <td>@row.Department</td>
                                <td class="mono">@row.Item</td>
                                <td>@row.JobCode</td>
                                <td>@(row.EntrDate?.ToString("MM/dd/yy") ?? "")</td>
                                <td class="descrptn">@row.Descrpn</td>
                                <td class="amount @(row.Amt < 0 ? "negative" : "")">
                                    @FormatAmount(row.Amt)
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="gl-detail-total">
                            <td colspan="@(TotalColspan - 1)">Net Activity</td>
                            <td class="amount @(_rows.Sum(r => r.Amt) < 0 ? "negative" : "")">
                                @FormatAmount(_rows.Sum(r => r.Amt))
                            </td>
                        </tr>
                        @if (DrillDown.EndingBalance.HasValue)
                        {
                            <tr class="gl-detail-balance-row gl-detail-ending">
                                <td colspan="@(TotalColspan - 1)"><strong>Ending Balance</strong></td>
                                <td class="amount @(DrillDown.EndingBalance.Value < 0 ? "negative" : "")">
                                    <strong>@FormatAmount(DrillDown.EndingBalance.Value)</strong>
                                </td>
                            </tr>
                        }
                    </tfoot>
                </table>
            </div>
        }
    </DialogContent>

    <DialogActions>
        @if (_rows.Count > 0)
        {
            <MudButton OnClick="ExportExcel"
                       Variant="Variant.Filled"
                       Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.TableChart"
                       Disabled="@_exporting">
                @(_exporting ? "Exporting..." : "Excel")
            </MudButton>
        }
        <MudButton OnClick="Close"
                   Variant="Variant.Text"
                   Color="Color.Default">
            Close
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public DrillDownRef DrillDown { get; set; } = null!;

    private List<GlDetailRow> _rows = new();
    private bool _loading = true;

    // Adjust colspan based on whether multi-entity/account columns are shown
    private int TotalColspan =>
        10   // Period, Ref, Source, Basis, Dept, Item, Job, Date, Description, Amount
        + (DrillDown.EntityIds.Count > 1 ? 1 : 0)
        + (DrillDown.AcctNums.Count > 1 ? 1 : 0);

    protected override async Task OnInitializedAsync()
    {
        await LoadDetailAsync();
    }

    private async Task LoadDetailAsync()
    {
        _loading = true;

        Logger.LogInformation(
            "GLDetailDialog loading — DbKey={DbKey} Label={Label} " +
            "Entities=[{Entities}] AcctNums=[{AcctNums}] Period={From}-{To}",
            UserSession.DbKey,
            DrillDown.DisplayLabel,
            string.Join(",", DrillDown.EntityIds),
            string.Join(",", DrillDown.AcctNums),
            DrillDown.PeriodFrom,
            DrillDown.PeriodTo);

        var result = await GlDetailService.GetDetailAsync(UserSession.DbKey, DrillDown);

        if (result.IsSuccess)
        {
            _rows = result.Data!.ToList();
            Logger.LogInformation(
                "GLDetailDialog loaded {Count} rows — Label={Label}",
                _rows.Count, DrillDown.DisplayLabel);
        }
        else
        {
            Logger.LogError(
                "GLDetailDialog load failed — {Error}", result.ErrorMessage);
            AlertSvc.AddError($"Failed to load GL detail: {result.ErrorMessage}");
        }

        _loading = false;
    }

    private void Close() => MudDialog.Close();

    /// <summary>Formats YYYYMM as MM/YYYY for display.</summary>
    private static string FormatPeriod(string period) =>
        period.Length == 6
            ? $"{period[4..6]}/{period[0..4]}"
            : period;

    private static string FormatAmount(decimal amt) =>
        amt.ToString("N2");

    private bool _exporting = false;

    private async Task ExportExcel()
    {
        _exporting = true;
        try
        {
            var bytes = BuildDetailExcel();
            var fileName = $"GLDetail_{DrillDown.PeriodFrom}-{DrillDown.PeriodTo}_{DateTime.Now:yyyyMMddHHmmss}.xlsx";
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFile", fileName,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", base64);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "GLDetailDialog Excel export failed");
            AlertSvc.AddError("Excel export failed.");
        }
        finally
        {
            _exporting = false;
        }
    }

    private byte[] BuildDetailExcel()
    {
        using var wb = new ClosedXML.Excel.XLWorkbook();
        var ws = wb.Worksheets.Add("GL Detail");

        // Title rows
        ws.Cell(1, 1).Value = $"GL Detail — {DrillDown.DisplayLabel}";
        ws.Cell(1, 1).Style.Font.Bold = true;
        ws.Cell(1, 1).Style.Font.FontSize = 12;
        ws.Cell(2, 1).Value = $"Period: {DrillDown.PeriodFrom} – {DrillDown.PeriodTo}   Entities: {string.Join(", ", DrillDown.EntityIds)}";
        ws.Cell(2, 1).Style.Font.FontSize = 9;
        ws.Cell(2, 1).Style.Font.FontColor = ClosedXML.Excel.XLColor.Gray;

        // Column headers (row 4)
        var headers = new[] { "Period", "Ref", "Source", "Basis", "Entity",
                               "Account", "Dept", "Item", "Job", "Date", "Description", "Amount" };
        for (int i = 0; i < headers.Length; i++)
        {
            var hCell = ws.Cell(4, i + 1);
            hCell.Value = headers[i];
            hCell.Style.Font.Bold = true;
            hCell.Style.Fill.BackgroundColor = ClosedXML.Excel.XLColor.FromHtml("#D9E1F2");
            hCell.Style.Border.BottomBorder = ClosedXML.Excel.XLBorderStyleValues.Medium;
        }

        // Starting/ending balance rows + data rows
        int row = 5;
        if (DrillDown.StartingBalance.HasValue) { var c=ws.Cell(row,11); c.Value="Starting Balance"; c.Style.Font.Bold=true; c.Style.Fill.BackgroundColor=ClosedXML.Excel.XLColor.FromHtml("#DEEAF1"); var d=ws.Cell(row,12); d.Value=(double)DrillDown.StartingBalance.Value; d.Style.Font.Bold=true; d.Style.NumberFormat.Format=@"#,##0.00_);(#,##0.00);\"-\""; d.Style.Alignment.Horizontal=ClosedXML.Excel.XLAlignmentHorizontalValues.Right; d.Style.Fill.BackgroundColor=ClosedXML.Excel.XLColor.FromHtml("#DEEAF1"); row++; }
        foreach (var r in _rows)
        {
            ws.Cell(row, 1).Value  = FormatPeriod(r.Period);
            ws.Cell(row, 2).Value  = r.Ref;
            ws.Cell(row, 3).Value  = r.Source;
            ws.Cell(row, 4).Value  = r.Basis;
            ws.Cell(row, 5).Value  = r.EntityId;
            ws.Cell(row, 6).Value  = r.AcctNum.Trim();
            ws.Cell(row, 7).Value  = r.Department;
            ws.Cell(row, 8).Value  = r.Item;
            ws.Cell(row, 9).Value  = r.JobCode;
            ws.Cell(row, 10).Value = r.EntrDate?.ToString("MM/dd/yyyy") ?? "";
            ws.Cell(row, 11).Value = r.Descrpn;

            var amtCell = ws.Cell(row, 12);
            amtCell.Value = (double)r.Amt;
            amtCell.Style.NumberFormat.Format = @"#,##0.00_);(#,##0.00);""-""";
            amtCell.Style.Alignment.Horizontal = ClosedXML.Excel.XLAlignmentHorizontalValues.Right;
            row++;
        }

        // Total row
        ws.Cell(row, 11).Value = "Total";
        ws.Cell(row, 11).Style.Font.Bold = true;
        var totalCell = ws.Cell(row, 12);
        totalCell.Value = (double)_rows.Sum(r => r.Amt);
        totalCell.Style.Font.Bold = true;
        totalCell.Style.NumberFormat.Format = @"#,##0.00_);(#,##0.00);""-""";
        totalCell.Style.Alignment.Horizontal = ClosedXML.Excel.XLAlignmentHorizontalValues.Right;
        totalCell.Style.Border.TopBorder = ClosedXML.Excel.XLBorderStyleValues.Thin;

        // Column widths
        ws.Column(11).Width = 40;
        ws.Column(12).Width = 16;
        ws.Columns(1, 10).AdjustToContents();
        ws.SheetView.Freeze(4, 0);

        using var ms = new System.IO.MemoryStream();
        wb.SaveAs(ms);
        return ms.ToArray();
    }
}
