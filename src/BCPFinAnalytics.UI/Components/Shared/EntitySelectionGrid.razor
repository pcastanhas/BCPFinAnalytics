@using BCPFinAnalytics.Common.DTOs

@*
    EntitySelectionGrid — searchable entity selection component.
    Client-side filtering with virtualization for performance.
    Projects removed — entity selection only.

    Mode parameter (SelectionMode):
      Include → user selects IDs to include
      Exclude → user selects IDs to exclude
      Range   → exactly 2 IDs; second must be >= first
*@

<div class="entity-grid-container">
    <!-- Search box -->
    <MudTextField @bind-Value="_searchText"
                  Placeholder="Search by ID or name..."
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Immediate="true"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Class="mb-2"
                  Disabled="@Disabled" />

    <!-- Virtualized selection list -->
    <div class="entity-grid @(Disabled ? "disabled" : "")">
        @if (!_filteredItems.Any())
        {
            <MudText Typo="Typo.caption" Class="pa-2" Color="Color.Secondary">
                @(Entities.Any() ? "No results found." : "Loading...")
            </MudText>
        }
        else
        {
            <Virtualize Items="_filteredItems" Context="item" OverscanCount="10">
                @{
                    var isSelected = SelectedIds.Contains(item.Id);
                }
                <div class="entity-row @(isSelected ? "selected" : "")"
                     @onclick="() => ToggleItem(item.Id)">
                    <MudCheckBox Value="@isSelected"
                                 ValueChanged="@((bool v) => ToggleItem(item.Id))"
                                 Color="Color.Primary"
                                 Dense="true"
                                 Disabled="@Disabled" />
                    <span class="entity-id">@item.Id</span>
                    <span class="entity-name">@item.Name</span>
                </div>
            </Virtualize>
        }
    </div>

    <!-- Selection summary and validation -->
    <div class="entity-selection-summary mt-1">
        @if (Mode == BCPFinAnalytics.Common.Enums.SelectionMode.Range)
        {
            @if (SelectedIds.Count == 0)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary">Select exactly 2 items for range.</MudText>
            }
            else if (SelectedIds.Count == 1)
            {
                <MudText Typo="Typo.caption" Color="Color.Warning">Select 1 more item for range.</MudText>
            }
            else if (SelectedIds.Count == 2)
            {
                <MudText Typo="Typo.caption" Color="Color.Success">
                    Range: @SelectedIds[0] → @SelectedIds[1]
                </MudText>
            }
            else
            {
                <MudText Typo="Typo.caption" Color="Color.Error">Range requires exactly 2 items.</MudText>
            }
        }
        else
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                @SelectedIds.Count item(s) selected
            </MudText>
        }
    </div>
</div>

@code {
    [Parameter] public BCPFinAnalytics.Common.Enums.SelectionMode Mode { get; set; }
        = BCPFinAnalytics.Common.Enums.SelectionMode.Include;
    [Parameter] public List<string> SelectedIds { get; set; } = new();
    [Parameter] public EventCallback<List<string>> SelectedIdsChanged { get; set; }
    [Parameter] public List<EntityDto> Entities { get; set; } = new();
    [Parameter] public bool Disabled { get; set; } = false;

    private string _searchText = string.Empty;

    private record SelectionItem(string Id, string Name);

    private List<SelectionItem> _filteredItems => Entities
        .Select(e => new SelectionItem(e.EntityId, e.Name))
        .Where(i => string.IsNullOrEmpty(_searchText)
            || i.Id.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || i.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase))
        .OrderBy(i => SelectedIds.Contains(i.Id) ? 0 : 1)  // selected first
        .ThenBy(i => i.Id)
        .ToList();

    private async Task ToggleItem(string id)
    {
        if (Disabled) return;

        var current = new List<string>(SelectedIds);

        if (Mode == BCPFinAnalytics.Common.Enums.SelectionMode.Range)
        {
            if (current.Contains(id))
                current.Remove(id);
            else
            {
                if (current.Count >= 2) current.Clear();
                current.Add(id);
                if (current.Count == 2) current.Sort();
            }
        }
        else
        {
            if (current.Contains(id)) current.Remove(id);
            else current.Add(id);
        }

        await SelectedIdsChanged.InvokeAsync(current);
    }

    public bool IsValid => Mode switch
    {
        BCPFinAnalytics.Common.Enums.SelectionMode.Include => SelectedIds.Any(),
        BCPFinAnalytics.Common.Enums.SelectionMode.Exclude => SelectedIds.Any(),
        BCPFinAnalytics.Common.Enums.SelectionMode.Range   => SelectedIds.Count == 2,
        _                                                  => false
    };
}
