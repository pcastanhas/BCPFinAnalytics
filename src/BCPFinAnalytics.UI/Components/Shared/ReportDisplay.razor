@using BCPFinAnalytics.Common.Enums
@using BCPFinAnalytics.Common.Models
@inject IDialogService DialogService

@*
    ReportDisplay — row-type driven financial report renderer.
    Renders a ReportResult as a styled HTML table.
    Each row's RowType determines its CSS class and formatting.
    Supports both fixed-column and dynamic crosstab reports.
*@

@if (Result == null || !Result.HasData)
{
    @if (Result != null && !Result.HasData)
    {
        <MudAlert Severity="Severity.Info" Class="mt-2">
            No data returned for the selected criteria.
        </MudAlert>
    }
    return;
}

<!-- Report header -->
<div class="report-header mb-2">
    <MudText Typo="Typo.h6" Style="font-weight:600;">
        @Result.Metadata.ReportTitle
    </MudText>
    <MudText Typo="Typo.caption" Color="Color.Secondary">
        @Result.Metadata.EntityName
        @if (!string.IsNullOrEmpty(Result.Metadata.StartPeriod))
        {
            <span> &nbsp;|&nbsp; @Result.Metadata.StartPeriod
            @if (!string.IsNullOrEmpty(Result.Metadata.EndPeriod))
            {
                <span> — @Result.Metadata.EndPeriod</span>
            }
            </span>
        }
        <span> &nbsp;|&nbsp; Run: @Result.Metadata.RunDate.ToString("MM/dd/yyyy hh:mm tt")</span>
        <span> &nbsp;|&nbsp; DB: @Result.Metadata.DbKey</span>
        @if (Result.Metadata.WholeDollars)
        {
            <span> &nbsp;|&nbsp; Whole Dollars</span>
        }
    </MudText>
</div>

<!-- Scrollable report table -->
<div class="report-container">
    <table class="@("report-table" + (Result.Metadata.ShadeAlternateRows ? " report-table-zebra" : ""))">
        <thead>
            <tr>
                <th style="text-align:left; width:110px;">Account</th>
                <th style="text-align:left; min-width:200px;">Description</th>
                @foreach (var col in Result.Columns)
                {
                    <th style="width:@(col.Width.HasValue ? col.Width + "px" : "120px");">
                        @col.Header
                    </th>
                }
            </tr>
        </thead>
        <tbody>
            @{ int _detailIdx = 0; }
            @foreach (var row in Result.Rows)
            {
                var _zebraClass = (Result.Metadata.ShadeAlternateRows && row.RowType == RowType.Detail)
                    ? (_detailIdx++ % 2 == 0 ? "" : "row-alt")
                    : "";
                <tr class="@GetRowClass(row.RowType) @_zebraClass">
                    <td>@row.AccountCode</td>
                    <td style="padding-left: @(row.Indent * 16 + 12)px;">
                        @row.AccountName
                    </td>
                    @foreach (var col in Result.Columns)
                    {
                        var cell = row.Cells.TryGetValue(col.ColumnId, out var cv) ? cv : CellValue.Empty;
                        <td class="numeric @(cell.IsDrillable || cell.IsBudgetDrillable ? "drillable" : "") @(cell.CssClass ?? "")">
                            @if (cell.IsDrillable)
                            {
                                <span class="drill-link"
                                      @onclick="async () => await OnCellClicked(cell.DrillDown!)"
                                      title="Click to view GL detail">
                                    @RenderCellValue(row, col, cell)
                                </span>
                            }
                            else if (cell.IsBudgetDrillable)
                            {
                                <span class="drill-link budget-drill-link"
                                      @onclick="async () => await OnBudgetCellClicked(cell.BudgetDrillDown!)"
                                      title="Click to view budget detail">
                                    @RenderCellValue(row, col, cell)
                                </span>
                            }
                            else
                            {
                                @RenderCellValue(row, col, cell)
                            }
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter] public ReportResult? Result { get; set; }

    private string GetRowClass(RowType rowType) => rowType switch
    {
        RowType.SectionHeader => "row-section-header",
        RowType.SubHeader     => "row-sub-header",
        RowType.Detail        => "row-detail",
        RowType.Total         => "row-total",
        RowType.GrandTotal                  => "row-grand-total",
        RowType.UnpostedRetainedEarnings    => "row-unposted-retained-earnings",
        _                                   => "row-detail"
    };

    private string RenderCellValue(ReportRow row, ReportColumn col, CellValue cell)
    {
        // Check for display override (e.g. "N/A") — takes precedence over amount
        if (row.CellOverrides.TryGetValue(col.ColumnId, out var overrideText))
            return overrideText;

        // Header rows have no data
        if (row.RowType is RowType.SectionHeader or RowType.SubHeader)
            return string.Empty;

        if (cell.Amount is null)
            return string.Empty;

        return col.DataType switch
        {
            ColumnDataType.Currency => FormatCurrency(cell.Amount.Value),
            ColumnDataType.Percent  => $"{cell.Amount.Value:N2}%",
            ColumnDataType.Integer  => $"{cell.Amount.Value:N0}",
            ColumnDataType.Text     => cell.Amount.Value.ToString(),
            _                       => FormatCurrency(cell.Amount.Value)
        };
    }

    private async Task OnCellClicked(DrillDownRef drillDown)
    {
        var parameters = new DialogParameters
        {
            { nameof(GLDetailDialog.DrillDown), drillDown }
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey  = true,
            MaxWidth          = MaxWidth.Large,
            FullWidth         = true,
            CloseButton       = true
        };

        await DialogService.ShowAsync<GLDetailDialog>(
            "GL Detail", parameters, options);
    }

    private async Task OnBudgetCellClicked(BudgetDrillDownRef drillDown)
    {
        var parameters = new DialogParameters
        {
            { nameof(BudgetDetailDialog.DrillDown), drillDown }
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey  = true,
            MaxWidth          = MaxWidth.Large,
            FullWidth         = true,
            CloseButton       = true
        };

        await DialogService.ShowAsync<BudgetDetailDialog>(
            "Budget Detail", parameters, options);
    }

    private string FormatCurrency(decimal value)
    {
        if (Result == null) return value.ToString("N2");
        return Result.Metadata.WholeDollars
            ? $"{value:N0}"
            : $"{value:N2}";
    }
}
