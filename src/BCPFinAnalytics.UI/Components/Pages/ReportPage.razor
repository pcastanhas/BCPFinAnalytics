@using BCPFinAnalytics.Common.Models
@using BCPFinAnalytics.Services.Interfaces
@using BCPFinAnalytics.Services.Session
@using System.Text.Json
@inject IReportStrategyResolver StrategyResolver
@inject IScreenReportMapper ScreenMapper
@inject IExcelRenderer ExcelRenderer
@inject IPdfRenderer PdfRenderer
@inject UserSessionService UserSession
@inject ISnackbar Snackbar
@inject BCPFinAnalytics.UI.Services.AlertService AlertSvc
@inject ILogger<ReportPage> Logger
@inject BCPFinAnalytics.Services.Preflight.IReportPreflightService PreflightService
@inject IJSRuntime JS

@*
    ReportPage — side-by-side layout.
    Sidebar (480px) can be toggled left or right by the user.
*@

<div class="report-page-layout @(_sidebarOnRight ? "sidebar-right" : "sidebar-left")">

    <!-- ── SIDEBAR — Options ───────────────────────────── -->
    <div class="report-sidebar">
        <!-- Sidebar position toggle -->
        <div class="sidebar-toggle-bar">
            <MudTooltip Text="@(_sidebarOnRight ? "Move panel to left" : "Move panel to right")">
                <MudIconButton Icon="@(_sidebarOnRight
                                    ? Icons.Material.Filled.KeyboardDoubleArrowLeft
                                    : Icons.Material.Filled.KeyboardDoubleArrowRight)"
                               Size="Size.Small"
                               Color="Color.Default"
                               OnClick="() => _sidebarOnRight = !_sidebarOnRight" />
            </MudTooltip>
        </div>

        @if (_isRunning)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-1" />
        }
        <OptionsPanel @ref="_optionsPanel" OnRunReport="RunReport" IsRunning="@_isRunning" />
    </div>

    <!-- ── CONTENT — Report ────────────────────────────── -->
    <div class="report-content">
        @if (_reportResult != null)
        {
            <ReportDisplay Result="@_reportResult" />
        }
        else if (_hasRun && !_isRunning)
        {
            <MudAlert Severity="Severity.Info" Class="mt-2">
                No data returned for the selected criteria.
            </MudAlert>
        }
        else if (!_hasRun)
        {
            <div class="report-empty-state">
                <MudIcon Icon="@Icons.Material.Filled.BarChart"
                         Style="font-size:4rem; opacity:0.15;" />
                <MudText Typo="Typo.h6" Style="opacity:0.35; margin-top:12px;">
                    Configure options and click Display
                </MudText>
            </div>
        }
    </div>

</div>

@code {
    private OptionsPanel? _optionsPanel;
    private ReportResult? _reportResult;
    private bool _isRunning = false;
    private bool _hasRun = false;
    private bool _sidebarOnRight = false;

    private async Task RunReport((ReportOptions Options, OptionsPanel.OutputFormat Format) args)
    {
        var (options, format) = args;

        if (string.IsNullOrEmpty(options.ReportType))
        {
            Snackbar.Add("Please select a Report Type.", Severity.Warning);
            return;
        }

        _isRunning = true;
        _reportResult = null;
        _hasRun = false;
        StateHasChanged();

        var optionsJson = JsonSerializer.Serialize(options, new JsonSerializerOptions { WriteIndented = false });
        Logger.LogInformation(
            "Report execution started — ReportType={ReportType} Format={Format} DbKey={DbKey} UserId={UserId} Options={Options}",
            options.ReportType, format, options.DbKey, options.UserId, optionsJson);

        try
        {
            // ── Preflight validation — runs before every report, no exceptions ──
            var preflight = await PreflightService.ValidateAsync(options);
            if (!preflight.IsSuccess)
            {
                Logger.LogWarning(
                    "Report blocked by preflight — ReportType={ReportType} Reason={Reason}",
                    options.ReportType, preflight.ErrorMessage);
                AlertSvc.AddError(preflight.ErrorMessage);
                return;
            }

            var strategy = StrategyResolver.Resolve(options.ReportType);
            var result = await strategy.ExecuteAsync(options);

            if (!result.IsSuccess)
            {
                Logger.LogError("Report execution failed — ReportType={ReportType} Error={Error}",
                    options.ReportType, result.ErrorMessage);
                AlertSvc.AddError($"Report failed: {result.ErrorMessage}");
                return;
            }

            Logger.LogInformation(
                "Report execution complete — ReportType={ReportType} Rows={Rows} Format={Format}",
                options.ReportType, result.Data!.Rows.Count, format);

            switch (format)
            {
                case OptionsPanel.OutputFormat.Screen:
                    _reportResult = ScreenMapper.Prepare(result.Data!);
                    break;
                case OptionsPanel.OutputFormat.Excel:
                    await DownloadExcel(result.Data!);
                    break;
                case OptionsPanel.OutputFormat.Pdf:
                    await DownloadPdf(result.Data!);
                    break;
            }
        }
        catch (InvalidOperationException ex)
        {
            Logger.LogError(ex, "No strategy found for {ReportType}", options.ReportType);
            AlertSvc.AddError(ex.Message);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected report error — ReportType={ReportType}", options.ReportType);
            AlertSvc.AddError("An unexpected error occurred. Please try again.");
        }
        finally
        {
            _hasRun = true;
            _isRunning = false;
            StateHasChanged();
        }
    }

    private async Task DownloadExcel(ReportResult result)
    {
        try
        {
            var bytes = ExcelRenderer.Render(result);
            var fileName = $"{result.Metadata.ReportCode}_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";
            await DownloadFile(bytes, fileName, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Excel render failed");
            AlertSvc.AddError("Excel export failed.");
        }
    }

    private async Task DownloadPdf(ReportResult result)
    {
        try
        {
            var bytes = PdfRenderer.Render(result);
            var fileName = $"{result.Metadata.ReportCode}_{DateTime.Now:yyyyMMdd_HHmmss}.pdf";
            await DownloadFile(bytes, fileName, "application/pdf");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "PDF render failed");
            AlertSvc.AddError("PDF export failed.");
        }
    }

    private async Task DownloadFile(byte[] bytes, string fileName, string mimeType)
    {
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("downloadFile", fileName, mimeType, base64);
    }
}
