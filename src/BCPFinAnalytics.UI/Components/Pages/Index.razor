@page "/"
@using BCPFinAnalytics.Services.Session
@using MudBlazor
@inject UserSessionService UserSession
@inject ILogger<Index> Logger
@inject NavigationManager NavigationManager

<PageTitle>BCPFinAnalytics</PageTitle>

@if (!_sessionInitialized)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    <MudText Typo="Typo.body1" Class="pa-4">Initializing session...</MudText>
}
else if (!UserSession.IsValid)
{
    <MudAlert Severity="Severity.Error" Class="ma-4" Elevation="2">
        <MudText Typo="Typo.h6">Session Error</MudText>
        <MudText Typo="Typo.body1" Class="mt-2">@_sessionError</MudText>
        <MudText Typo="Typo.body2" Class="mt-1">
            Expected URL format: <strong>BCPFinAnalytics?db=PROD&amp;userid=username</strong>
        </MudText>
    </MudAlert>
}
else
{
    <ReportPage />
}

@code {
    private bool _sessionInitialized = false;
    private string _sessionError = string.Empty;

    protected override void OnInitialized()
    {
        var uri    = new Uri(NavigationManager.Uri);
        var query  = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var db     = query["db"]?.Trim();
        var userId = query["userid"]?.Trim();

        Logger.LogInformation(
            "BCPFinAnalytics session initializing — db={DbKey} userid={UserId}",
            db ?? "(missing)", userId ?? "(missing)");

        var result = UserSession.Initialize(db, userId);

        if (!result.IsSuccess)
        {
            _sessionError = result.ErrorMessage;
            Logger.LogWarning("Session init failed — {Error}", result.ErrorMessage);
        }
        else
        {
            Logger.LogInformation("Session OK — db={DbKey} userid={UserId}",
                UserSession.DbKey, UserSession.UserId);
        }

        _sessionInitialized = true;
    }
}
