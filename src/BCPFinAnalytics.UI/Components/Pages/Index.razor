@page "/"
@using BCPFinAnalytics.Services.Session
@using MudBlazor
@inject UserSessionService UserSession
@inject ILogger<Index> Logger
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageTitle>BCPFinAnalytics</PageTitle>

@if (!_sessionInitialized)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    <MudText Typo="Typo.body1" Class="pa-4">Initializing session...</MudText>
}
else if (!UserSession.IsValid)
{
    <MudAlert Severity="Severity.Error" Class="ma-4" Elevation="2">
        <MudText Typo="Typo.h6">Session Error</MudText>
        <MudText Typo="Typo.body1" Class="mt-2">@_sessionError</MudText>
        <MudText Typo="Typo.body2" Class="mt-1">
            Expected URL: <strong>BCPFinAnalytics?db=PROD&amp;userid=username</strong>
        </MudText>
        <MudText Typo="Typo.caption" Class="mt-1">URL: @NavigationManager.Uri</MudText>
    </MudAlert>
}
else
{
    <div style="background:lime;padding:20px;font-size:24px;">SESSION OK — REPORT PAGE LOADING</div>
    <ReportPage />
}

@code {
    private bool _sessionInitialized = false;
    private string _sessionError = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var uri   = new Uri(NavigationManager.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var db     = query["db"]?.Trim();
        var userId = query["userid"]?.Trim();

        // Write to browser console — persists even after page navigation
        await JS.InvokeVoidAsync("console.log",
            $"[BCPFinAnalytics] OnInitialized — db={db ?? "(missing)"} userid={userId ?? "(missing)"} uri={NavigationManager.Uri}");

        var result = UserSession.Initialize(db, userId);

        await JS.InvokeVoidAsync("console.log",
            $"[BCPFinAnalytics] Session result — IsSuccess={result.IsSuccess} Error={result.ErrorMessage} IsValid={UserSession.IsValid}");

        if (!result.IsSuccess)
            _sessionError = result.ErrorMessage;

        _sessionInitialized = true;

        await JS.InvokeVoidAsync("console.log",
            $"[BCPFinAnalytics] Done — IsValid={UserSession.IsValid} DbKey={UserSession.DbKey}");
    }
}
